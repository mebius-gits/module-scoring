# .env 環境變數範例（複製此檔案為 .env 並填入真實值）

# 資料庫連線字串 (SQLite 範例)
DATABASE_URL=sqlite:///./app.db

# PostgreSQL 範例：
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# MySQL 範例：
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/mydb

# Google Gemini API Key
GEMINI_API_KEY=your_key_here

# Gemini 模型名稱 (可選: gemini-2.5-flash, gemini-2.0-flash-lite, gemini-2.5-pro 等)
GEMINI_MODEL=gemini-2.5-flash

# 反向代理根路徑（部署在 Nginx 等反向代理後方時設定，例如 /api）
ROOT_PATH=

# 是否啟用 Swagger UI（/docs），正式環境建議設為 false
ENABLE_SWAGGER_UI=true